# Supabase PostgreSQL
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?schema=public"

# Public app URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Gmail SMTP. Use a Google App Password, not your normal Google password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-google-account@gmail.com"
SMTP_PASS="your-16-character-google-app-password"
SMTP_FROM="KUP EXPORTER <your-google-account@gmail.com>"

# Supabase Storage for deployed file uploads
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="[SUPABASE-SERVICE-ROLE-KEY]"
SUPABASE_STORAGE_BUCKET="shipping-agent-uploads"
